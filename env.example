DWAVE_API_KEY=your-dwave-api-token-here

# --- Node file ownership ----------------------------------------------------
# The node container runs as a non-root 'quip' user (uid 1000 by default)
# and chowns /data to match on first start. The setup step seeds these from
# your host uid/gid via `id -u` / `id -g`; override here if you need to
# run under a different user. PUID=0 keeps legacy root-mode.
# PUID=1000
# PGID=1000

# --- HTTP(S) front-door (Caddy) ---------------------------------------------
# Hostname Caddy serves on. 'localhost' = HTTP on :80 (with self-signed :443
# via Caddy's internal CA). A real DNS name = automatic Let's Encrypt cert,
# HTTPS on :443, HTTP→HTTPS redirect. Port 80 must be reachable from the
# internet for the ACME HTTP-01 challenge.
QUIP_HOSTNAME=localhost

# Email used by Caddy to register with Let's Encrypt. Required when
# QUIP_HOSTNAME is a real DNS name; ignored otherwise.
CERT_EMAIL=

# --- Dashboard + Postgres (bundled with every node profile) -----------------
# Postgres is only reachable inside the compose network (port 5432 is not
# published to the host), so the default password is fine for local use.
# Override for defense-in-depth on shared hosts:
# POSTGRES_PASSWORD=quip
# POSTGRES_DB=quip
# POSTGRES_USER=quip

# Quip node URL the indexer polls. Default points at the local node via the
# "quip-node" compose network alias — requires the node's REST API enabled in
# data/config.toml. For miner-only nodes, override to a public full node:
#   QUIP_NODE_URL=https://qpu-1.nodes.quip.network
# QUIP_NODE_URL=http://quip-node:80
# QUIP_NODE_TOKEN=
