# Caddy front-door for the Quip stack.
#
# QUIP_HOSTNAME controls listen addresses and TLS in a single value:
#
#   Dev / localhost (HTTP only):
#     QUIP_HOSTNAME=:20049
#   Bare port -> HTTP on that port, no auto-TLS.
#
#   Production (auto-TLS on :443 + :20049, :80 auto-redirects to :443):
#     QUIP_HOSTNAME=cpu-1.nodes.quip.network, cpu-1.nodes.quip.network:20049
#   Two comma-separated bare DNS entries: Caddy provisions one Let's Encrypt
#   cert covering both, auto-binds :443 + :20049, and adds the :80 redirect.
#   Port 80 must be reachable from the internet for the ACME HTTP-01 challenge.
#
# CERT_EMAIL registers the ACME account. Default issuer is Let's Encrypt with
# ZeroSSL as automatic fallback (Caddy 2.6+). To pin ZeroSSL, uncomment the
# cert_issuer line and set ZEROSSL_API_KEY in .env.
{
	email {$CERT_EMAIL}
	# cert_issuer zerossl {$ZEROSSL_API_KEY}
}

(routing) {
	# Substrate JSON-RPC (HTTP POST + WebSocket on the same path). Active only
	# under validator-* profiles; cpu/cuda profiles 502 cleanly because there's
	# no quip-validator to proxy to. handle_path strips the /rpc prefix so the
	# substrate node sees requests at /.
	handle_path /rpc/* {
		reverse_proxy quip-validator:9944
	}

	# Optional faucet sidecar (`--profile faucet`). The bot serves /request
	# and /health; handle_path strips /api/faucet so external POST
	# /api/faucet/request reaches the bot's POST /request.
	handle_path /api/faucet/* {
		reverse_proxy quip-faucet:8087
	}

	# Miner telemetry / v1 REST.
	handle /api/v1/* {
		reverse_proxy quip-node:80
	}

	# Dashboard SPA + its /api/telemetry, /api/health, etc.
	reverse_proxy quip-dashboard:3001
}

{$QUIP_HOSTNAME} {
	import routing
}
